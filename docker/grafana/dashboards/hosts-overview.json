{
  "dashboard": {
    "title": "PolicyCollector — Hosts Overview",
    "uid": "policycollector-hosts",
    "version": 1,
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Hosts",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS count FROM host_latest",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {},
            "mappings": []
          }
        }
      },
      {
        "id": 2,
        "title": "Online Hosts (last 2h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS count FROM host_latest WHERE last_seen > NOW() - INTERVAL '2 hours'",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "steps": [{ "color": "green", "value": 0 }] }
          }
        }
      },
      {
        "id": 3,
        "title": "Offline Hosts (> 24h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS count FROM host_latest WHERE last_seen < NOW() - INTERVAL '24 hours'",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }
          }
        }
      },
      {
        "id": 4,
        "title": "Host List",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
        "targets": [
          {
            "rawSql": "SELECT hostname, domain, os_version, agent_version, last_seen, status FROM host_latest ORDER BY last_seen DESC LIMIT 100",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Agents Check-in Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
        "targets": [
          {
            "rawSql": "SELECT time_bucket('1 hour', collected_at) AS time, COUNT(*) AS check_ins FROM collection_snapshots WHERE collected_at >= now() - INTERVAL '7 days' GROUP BY 1 ORDER BY 1",
            "format": "time_series",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
