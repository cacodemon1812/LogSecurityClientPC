{
  "dashboard": {
    "title": "PolicyCollector — Policy Violations",
    "uid": "policycollector-violations",
    "version": 1,
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Open Critical Violations",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS count FROM policy_violations WHERE resolved = false AND severity = 'critical'",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }
          }
        }
      },
      {
        "id": 2,
        "title": "Open High Severity",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS count FROM policy_violations WHERE resolved = false AND severity = 'high'",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Total Open Violations",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS count FROM policy_violations WHERE resolved = false",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Violations by Severity",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "rawSql": "SELECT severity, COUNT(*) AS count FROM policy_violations WHERE resolved = false GROUP BY severity",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Top Violated Rules",
        "type": "barchart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "rawSql": "SELECT rule_id, COUNT(*) AS count FROM policy_violations WHERE resolved = false GROUP BY rule_id ORDER BY count DESC LIMIT 10",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Recent Violations",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
        "targets": [
          {
            "rawSql": "SELECT hostname, rule_id, severity, message, detected_at FROM policy_violations WHERE resolved = false ORDER BY detected_at DESC LIMIT 200",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "New Violations Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
        "targets": [
          {
            "rawSql": "SELECT time_bucket('1 hour', detected_at) AS time, COUNT(*) AS violations FROM policy_violations WHERE detected_at >= now() - INTERVAL '7 days' GROUP BY 1 ORDER BY 1",
            "format": "time_series",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
